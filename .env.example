# Example configuration for Hermes Project
# Copy to .env and fill in real values before running against D1/Chroma/Hermes.

# Core paths
PROJECT_ROOT=.
HERMES_HOME=~/.hermes

# Cloudflare D1
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_FINANCE_D1_DATABASE_ID=

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000

# Hermes delivery target for operational/news pushes
# Examples: qqbot, telegram, qqbot:group:<id>, telegram:<chat_id>
HERMES_NEWS_TARGET=qqbot

# Optional path overrides
# HERMES_PROJECT_REPORT_DIR=./doctor-reports
# HERMES_PROJECT_ARCHIVE_DIR=./archive
# HERMES_PROJECT_DOCUMENT_ARCHIVE_DIR=./archive/documents
# HERMES_CRON_JOBS_FILE=~/.hermes/cron/jobs.json
# REUTERS_OUTPUT_FILE=./reuters_latest.md
# BLOOMBERG_OUTPUT_FILE=./bloomberg_latest.md
# BLOOMBERG_RSS_OUTPUT_FILE=./bloomberg_rss_latest.md

# Optional integrations
FIRECRAWL_API_KEY=
